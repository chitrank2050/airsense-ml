# AirSense ML — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.dev or .env.prod and fill in real values.
# Never commit .env.dev or .env.prod to git — they may contain secrets.
#
# Priority order:
#   1. Environment variables (e.g. API_PORT=9000 make api)
#   2. This .env file
#   3. Default values in config.py
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# Controls which .env file pydantic-settings loads
# Values: dev | prod
ENV=dev

# ── API Server ────────────────────────────────────────────────────────────────
# Host to bind — use 127.0.0.1 locally, 0.0.0.0 in Docker/Render
API_HOST=127.0.0.1
API_PORT=8000

# Debug mode — enables full tracebacks in HTTP error responses
# Never set true in production — exposes internal code structure
API_DEBUG=false

# Reload on file change — dev only, always false in production
API_RELOAD=true

# API versioning prefix
API_PREFIX=/v1

# ── API Documentation ─────────────────────────────────────────────────────────
# Set to null to disable in production if you don't want docs exposed
API_DOCS_URL=/docs
API_REDOC_URL=/redoc
API_OPENAPI_URL=/openapi.json

# ── API Metadata ──────────────────────────────────────────────────────────────
API_TITLE=AirSense ML API
API_VERSION=1.0.0

# ── CORS Middleware ───────────────────────────────────────────────────────────
# JSON array of allowed origins
# Production: replace with your actual frontend URL
API_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API_ALLOW_CREDENTIALS=true
API_ALLOWED_METHODS=["*"]
API_ALLOWED_HEADERS=["*"]

# ── Logging ───────────────────────────────────────────────────────────────────
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# DEBUG   — verbose, use during development only
# INFO    — normal operation, recommended for production
# WARNING — only problems, minimal noise
LOG_LEVEL=INFO

# Enable file logging — writes to logs/airsense.log
# Recommended true in production, false locally (stdout is enough)
ENABLE_LOG_FILE=false
LOG_FILE_NAME=airsense.log
LOG_FILE_RETENTION=30 days

# ── Model ─────────────────────────────────────────────────────────────────────
# Switch to best_model_tuned.pkl after hyperparameter tuning
MODEL_NAME=best_model.pkl
MODEL_DIR=models
DATASET_CONFIG=configs/delhi.yaml
MODEL_CONFIG=configs/model_config.yaml

# ── MLflow ────────────────────────────────────────────────────────────────────
# Modules to silence in logs — comma separated
# These produce noisy warnings that are acknowledged and safe to suppress
LOG_SILENCE_MODULES=["mlflow.sklearn","mlflow.utils.environment","mlflow.models.model"]