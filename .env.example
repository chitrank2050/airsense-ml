# AirSense ML — Environment Configuration
# Copy this file to .env.dev or .env.prod and fill in values.
# Never commit .env.dev or .env.prod to git.

# ── Environment ───────────────────────────────────────────────
ENV=dev

# ── API ───────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
API_RELOAD=true
API_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Model ─────────────────────────────────────────────────────
MODEL_NAME=best_model.pkl
MODEL_DIR=models
DATASET_CONFIG=configs/delhi.yaml
MODEL_CONFIG=configs/model_config.yaml